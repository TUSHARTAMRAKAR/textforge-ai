# ─────────────────────────────────────────────
#  TextForge AI — Backend Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Gemini API (Free — get key at aistudio.google.com, no card needed)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/textforge?retryWrites=true&w=majority

# CORS — comma-separated list of allowed frontend origins
# Local dev:    http://localhost:3000
# With Vercel:  http://localhost:3000,https://textforge-ai.vercel.app
CLIENT_URL=http://localhost:3000

# Rate Limiting (general API limit)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
